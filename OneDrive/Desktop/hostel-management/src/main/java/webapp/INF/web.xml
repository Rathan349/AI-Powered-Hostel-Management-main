<?xml version="1.0" encoding="UTF-8"?>
<web-app 
    xmlns="http://xmlns.jcp.org/xml/ns/javaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://xmlns.jcp.org/xml/ns/javaee 
        http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
    version="3.1">

    <display-name>Hostel Management System</display-name>

    <!-- ============================
         LOGIN SERVLET
    ============================== -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.hostel.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/login</url-pattern>
    </servlet-mapping>


    <!-- ============================
         STUDENT SERVLET
    ============================== -->
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>com.hostel.servlet.StudentServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/api/students</url-pattern>
    </servlet-mapping>


    <!-- ============================
         ROOM SERVLET
    ============================== -->
    <servlet>
        <servlet-name>RoomServlet</servlet-name>
        <servlet-class>com.hostel.servlet.RoomServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RoomServlet</servlet-name>
        <url-pattern>/api/rooms</url-pattern>
    </servlet-mapping>


    <!-- ============================
         ALLOCATION SERVLET
    ============================== -->
    <servlet>
        <servlet-name>AllocationServlet</servlet-name>
        <servlet-class>com.hostel.servlet.AllocationServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AllocationServlet</servlet-name>
        <url-pattern>/api/allocations</url-pattern>
    </servlet-mapping>


    <!-- ============================
         Welcome Page (Login Page)
    ============================== -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
